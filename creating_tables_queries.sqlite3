-- database: ./database.db

CREATE TABLE users (
  user_id INTEGER PRIMARY KEY AUTOINCREMENT,
  username VARCHAR(20) UNIQUE,
  email VARCHAR(100) UNIQUE,
  password VARCHAR(255)
);

CREATE TABLE alert_type (
  type_id INTEGER PRIMARY KEY,
  type_desc VARCHAR(20)
);

CREATE TABLE product_status (
  status_id INTEGER PRIMARY KEY,
  status_desc VARCHAR(20)
);

CREATE TABLE products (
  product_id INTEGER PRIMARY KEY AUTOINCREMENT,
  product_name VARCHAR(20),
  description VARCHAR(100),
  price_suggested INTEGER,
  seller_key INTEGER,
  image_url VARCHAR(255),
  date_posted DATE,
  status INTEGER,
  FOREIGN KEY (seller_key) REFERENCES users(user_id),
  FOREIGN KEY (status) REFERENCES product_status(status_id)
);

CREATE TABLE offer_status (
  status_id INTEGER PRIMARY KEY,
  status_desc VARCHAR(20)
);

CREATE TABLE offers (
  offer_id INTEGER PRIMARY KEY AUTOINCREMENT,
  product_key INTEGER,
  seller_key INTEGER,
  buyer_key INTEGER,
  offer_price INTEGER,
  message VARCHAR(255),
  date_sent DATE,
  status INTEGER,
  FOREIGN KEY (product_key) REFERENCES products(product_id),
  FOREIGN KEY (seller_key) REFERENCES users(user_id),
  FOREIGN KEY (buyer_key) REFERENCES users(user_id),
  FOREIGN KEY (status) REFERENCES offer_status(status_id)
);

CREATE TABLE alert_status (
  status_id INTEGER PRIMARY KEY,
  status_desc VARCHAR(20)
);

CREATE TABLE alerts (
  alert_id INTEGER PRIMARY KEY AUTOINCREMENT,
  user_key INTEGER,
  offer_key INTEGER,
  alert_type INTEGER,
  message VARCHAR(255),
  date_created DATE,
  status INTEGER,
  FOREIGN KEY (user_key) REFERENCES users(user_id),
  FOREIGN KEY (offer_key) REFERENCES offers(offer_id),
  FOREIGN KEY (alert_type) REFERENCES alert_type(type_id),
  FOREIGN KEY (status) REFERENCES alert_status(status_id)
);

CREATE TABLE locations (
  location_id INTEGER PRIMARY KEY AUTOINCREMENT,
  location_name VARCHAR(20),
  description VARCHAR(50),
  x_coord VARCHAR(20),
  y_coord VARCHAR(20)
);

CREATE TABLE meetup_status (
  status_id INTEGER PRIMARY KEY,
  status_desc VARCHAR(20)
);

CREATE TABLE meetups (
  meetup_id INTEGER PRIMARY KEY AUTOINCREMENT,
  offer_key INTEGER,
  location_key INTEGER,
  meetup_time DATE,
  status INTEGER,
  FOREIGN KEY (offer_key) REFERENCES offers(offer_id),
  FOREIGN KEY (location_key) REFERENCES locations(location_id),
  FOREIGN KEY (status) REFERENCES meetup_status(status_id)
);
